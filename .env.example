# Database (для локального запуску поза Docker — localhost)
# У docker-compose DATABASE_URL перевизначається на хост `db`
DATABASE_URL="postgresql://stezhky:stezhky@localhost:5432/stezhky?schema=public"

# Публічний URL додатку
APP_URL="http://localhost:3000"

# Strava API — https://www.strava.com/settings/api
# Authorization Callback Domain: localhost
STRAVA_CLIENT_ID="264213"
STRAVA_CLIENT_SECRET="3a153b2b57d97a23b83a9697c26200a8ebb10f83"

# Секрет для cookie-сесії (мін. 32 символи)
SESSION_SECRET="change-me-to-a-long-random-secret-string"

# Опційно: ключ OpenRouteService (профіль foot-hiking)
# Без ключа використовується Valhalla pedestrian (стежки, майже без доріг)
# https://openrouteservice.org/
# OPENROUTESERVICE_API_KEY=""
